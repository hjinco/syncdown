{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"//#lint": {
			"outputs": []
		},
		"//#format": {
			"outputs": []
		},
		"//#check": {
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["typecheck", "^typecheck"],
			"outputs": []
		}
	}
}
