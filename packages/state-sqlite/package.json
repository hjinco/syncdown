{
	"name": "@syncdown/state-sqlite",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"typecheck": "bun run ./scripts/generate-migrations.ts && tsgo -p ./tsconfig.json --noEmit --pretty false",
		"test": "bun run ./scripts/generate-migrations.ts && bun test ./src/index.test.ts",
		"db:generate": "drizzle-kit generate --config ./drizzle.config.ts && bun run ./scripts/generate-migrations.ts",
		"db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts"
	},
	"dependencies": {
		"@syncdown/core": "workspace:*",
		"drizzle-orm": "^0.44.5"
	},
	"devDependencies": {
		"drizzle-kit": "^0.31.4"
	}
}
