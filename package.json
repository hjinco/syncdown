{
	"name": "@syncdown/workspace",
	"private": true,
	"version": "0.1.0",
	"license": "Apache-2.0",
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"changeset": "changeset",
		"turbo": "turbo",
		"build": "turbo run build --filter=docs",
		"build:docs": "turbo run build --filter=docs",
		"lint": "biome lint .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"check": "biome check .",
		"typecheck": "turbo run typecheck && bun x tsc -p ./scripts/tsconfig.json --pretty false",
		"test": "turbo run test",
		"release:cli:version": "changeset version",
		"release:cli:binary:local": "bun ./scripts/build-cli-release-binary.ts",
		"release:cli:binary:smoke": "bun ./scripts/smoke-cli-release-binary.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@changesets/cli": "^2.30.0",
		"@types/node": "^22.13.10",
		"@typescript/native-preview": "^7.0.0-dev.20260316.1",
		"bun-types": "npm:@types/bun@^1.3.2",
		"turbo": "^2.5.0",
		"typescript": "^5.8.2"
	}
}
